---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Profilim | Agora Go Akademisi">
  
  <div class="bg-white dark:bg-gray-900 min-h-screen font-sans text-gray-800 dark:text-gray-200 pb-20 transition-colors duration-300">
    
    <div class="max-w-3xl mx-auto px-6 pt-24 pb-12 text-center border-b border-gray-100 dark:border-gray-800">
        
        <div class="inline-block relative mb-6">
            <div class="w-32 h-32 rounded-full overflow-hidden border border-gray-100 dark:border-gray-700 shadow-sm mx-auto bg-gray-50 dark:bg-gray-800 flex items-center justify-center">
                 <span id="avatar-initial" class="text-5xl font-light text-gray-400 dark:text-gray-500">?</span>
            </div>
            <button class="absolute bottom-1 right-1 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 p-2 rounded-full hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-500 dark:text-gray-400 shadow-sm transition">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
            </button>
        </div>

        <h1 id="display-username" class="text-4xl font-bold tracking-tight text-gray-900 dark:text-white mb-2">Yükleniyor...</h1>
        <p id="display-email" class="text-xl text-gray-400 dark:text-gray-500 font-light mb-6">...</p>
        
        <div class="flex items-center justify-center gap-2 text-sm text-gray-400 dark:text-gray-500">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            <span>İzmir, Türkiye</span>
        </div>

    </div>

    <div class="max-w-3xl mx-auto px-6 py-12">
        
        <section class="mb-16">
            <h2 class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-8 text-center">İlerleme Durumu</h2>
            
            <div class="max-w-xl mx-auto flex flex-col items-center gap-6 p-8 rounded-2xl bg-gray-50/80 dark:bg-gray-800/60 border border-gray-100 dark:border-gray-800 shadow-sm relative overflow-hidden">
                <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue-400 via-indigo-500 to-purple-600"></div>

                <span class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-widest mt-2">Mevcut Seviye</span>
                <span class="text-5xl font-extrabold text-gray-900 dark:text-white font-serif tracking-tight" id="display-rank">20 Kyu</span>
                
                <div class="w-full space-y-3">
                    <div class="flex justify-between text-[10px] font-bold text-gray-400 uppercase">
                        <span>Başlangıç (30 Kyu)</span>
                        <span>Usta (1 Dan)</span>
                    </div>
                    <div class="h-3 w-full bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden shadow-inner">
                        <div id="rank-spectrum" class="h-full bg-gradient-to-r from-blue-500 to-purple-600 rounded-full transition-all duration-1000 ease-out" style="width: 0%"></div>
                    </div>
                </div>

                <div class="w-full space-y-2 mt-4">
                    <div class="flex items-center justify-between text-xs text-gray-500 dark:text-gray-400">
                        <span>Sonraki seviye</span>
                        <span id="next-rank-label" class="font-semibold text-gray-700 dark:text-gray-200">19 Kyu</span>
                    </div>
                    <div class="h-2 w-full bg-gray-200/80 dark:bg-gray-700/80 rounded-full overflow-hidden">
                        <div id="xp-bar" class="h-full bg-gradient-to-r from-emerald-400 to-lime-400 rounded-full transition-all duration-700 ease-out" style="width: 0%"></div>
                    </div>
                    <p id="xp-text" class="text-[11px] text-gray-500 dark:text-gray-400 text-right">0 / 100 XP</p>
                </div>

                <div class="w-full pt-4 mt-4 border-t border-dashed border-gray-200 dark:border-gray-700">
                    <h3 class="text-[11px] font-semibold uppercase tracking-[0.16em] text-gray-400 dark:text-gray-500 mb-3 text-center md:text-left">Başarı Rozetleri</h3>
                    <div class="flex flex-wrap items-center justify-center md:justify-start gap-3">
                        <div class="h-9 w-9 rounded-full border border-amber-300/60 bg-amber-100/40 dark:bg-amber-900/40 flex items-center justify-center text-amber-500 text-lg">★</div>
                        <div class="h-9 w-9 rounded-full border border-sky-300/50 bg-sky-100/30 dark:bg-sky-900/40 flex items-center justify-center text-sky-400 text-base">♟</div>
                        <div class="h-9 w-9 rounded-full border border-emerald-300/60 bg-emerald-100/40 dark:bg-emerald-900/40 flex items-center justify-center text-emerald-500 text-base">✓</div>
                        <div class="h-9 w-9 rounded-full border border-gray-300/70 bg-gray-100/40 dark:bg-gray-800 flex items-center justify-center text-gray-400 text-xs">
                            +?
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="mb-16">
            <h2 class="text-xs font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-6 text-center md:text-left">Hakkında</h2>
            <div class="text-lg text-gray-700 dark:text-gray-300 leading-relaxed font-serif text-center md:text-left">
                Go oyunu tutkunu. Agora Go Akademisi'nde strateji ve taktik üzerine çalışıyor. 
                Hedefi Dan seviyesine ulaşmak ve turnuvalarda başarı elde etmek.
            </div>
        </section>

        <div class="border-t border-gray-100 dark:border-gray-800 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
            <div class="text-sm text-gray-400 dark:text-gray-600">
                Agora Go Akademisi © 2026
            </div>
            <button id="logout-btn" class="text-red-500 hover:text-red-700 dark:text-red-400 dark:hover:text-red-300 text-sm font-medium transition-colors">
                Oturumu Kapat
            </button>
        </div>

    </div>
  </div>

</Layout>

<script>
  import { supabase } from '../lib/supabase';

  async function initProfile() {
    const { data: { user } } = await supabase.auth.getUser();

    if (!user) {
      window.location.href = '/signup';
      return;
    }

    // DOM Elemanları
    const els = {
        username: document.getElementById('display-username'),
        email: document.getElementById('display-email'),
        avatarInitial: document.getElementById('avatar-initial'),
        displayRank: document.getElementById('display-rank'),
        rankSpectrum: document.getElementById('rank-spectrum'),
        nextRankLabel: document.getElementById('next-rank-label'),
        xpBar: document.getElementById('xp-bar'),
        xpText: document.getElementById('xp-text')
    };

    if (els.email) els.email.textContent = user.email || "";

    // KULLANICI VERİSİNİ ÇEK
    const { data: profile, error } = await supabase
      .from('agorasusers')
      .select('*')
      .eq('id', user.id)
      .single();

    if (error) console.error('Profil hatası:', error);

    const displayName = profile?.username || user.email?.split('@')[0] || "Oyuncu";
    
    // UI Güncelleme
    if (els.username) els.username.textContent = displayName;
    if (els.avatarInitial) els.avatarInitial.textContent = (displayName[0] || '?').toUpperCase();

    // --- RÜTBE VE SPEKTRUM GÖSTERİMİ ---
    if (profile && els.displayRank) {
        const rankText = profile.rank || "30 Kyu";
        els.displayRank.textContent = rankText;
        
        // Kyu değerini parse edip spektrum genişliğini ayarlama (Örn: 30 Kyu = 0%, 1 Dan = 100%)
        if (els.rankSpectrum) {
            let percentage = 0;
            const rankMatch = rankText.match(/(\d+)\s*Kyu/i);
            
            if (rankMatch) {
                const kyuValue = parseInt(rankMatch[1], 10);
                // 30 Kyu -> 0%, 1 Kyu -> ~96%
                percentage = Math.max(0, ((30 - kyuValue) / 30) * 100);
            } else if (rankText.toLowerCase().includes('dan')) {
                // Dan seviyesi ise bar full dolsun
                percentage = 100;
            }
            
            els.rankSpectrum.style.width = `${percentage}%`;
        }

        // Bir sonraki rütbe ve XP çubuğu (varsayılan: 0-100 XP, profile.xp alanı varsa onu kullan)
        const rankMatchNext = rankText.match(/(\d+)\s*Kyu/i);
        if (rankMatchNext && els.nextRankLabel) {
            const currentKyu = parseInt(rankMatchNext[1], 10);
            const nextKyu = Math.max(1, currentKyu - 1);
            els.nextRankLabel.textContent = `${nextKyu} Kyu`;
        } else if (rankText.toLowerCase().includes('dan') && els.nextRankLabel) {
            els.nextRankLabel.textContent = "Dan içi ilerleme";
        }

        const currentXp = typeof profile.xp === 'number' ? profile.xp : 0;
        const clampedXp = Math.max(0, Math.min(100, currentXp));
        if (els.xpBar) {
            els.xpBar.style.width = `${clampedXp}%`;
        }
        if (els.xpText) {
            els.xpText.textContent = `${clampedXp} / 100 XP`;
        }
    }
  }

  // Çıkış İşlemi
  const logoutBtn = document.getElementById('logout-btn');
  if (logoutBtn) {
      logoutBtn.addEventListener('click', async () => {
          await supabase.auth.signOut();
          window.location.href = '/signup';
      });
  }

  initProfile();
</script>