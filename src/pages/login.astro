---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Giriş Yap | Agora Go Akademisi">
  <main class="min-h-screen flex items-center justify-center bg-gradient-to-br from-slate-900 via-slate-950 to-slate-900 px-4 py-16">
    <div class="relative max-w-md w-full">
      <div class="absolute -inset-0.5 rounded-3xl bg-gradient-to-r from-blue-500/40 via-cyan-400/40 to-emerald-400/40 blur-2xl opacity-60"></div>

      <section class="relative rounded-3xl bg-white/10 dark:bg-slate-900/40 border border-white/10 shadow-2xl backdrop-blur-2xl px-8 py-10 flex flex-col items-center gap-6">
        <div class="flex flex-col items-center gap-3 text-center">
          <span class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-3 py-1 text-xs font-medium uppercase tracking-[0.2em] text-sky-300">
            Agora Go Akademisi
          </span>
          <h1 class="text-3xl md:text-4xl font-semibold tracking-tight text-white">
            Tek tıkla giriş yap
          </h1>
          <p class="text-sm text-sky-100/70 max-w-sm">
            E-posta ve şifreyle uğraşma. Hesabına sadece Google ile güvenli şekilde giriş yap.
          </p>
        </div>

        <button
          id="google-login"
          class="group inline-flex w-full items-center justify-center gap-3 rounded-full bg-white text-slate-900 px-4 py-3 text-sm font-semibold shadow-lg shadow-sky-500/20 transition hover:-translate-y-0.5 hover:shadow-xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-400"
        >
          <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-white">
            <svg class="h-5 w-5" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="#EA4335" d="M11.99 13.19v-2.72h9.18c.09.49.14 1.06.14 1.72 0 2.14-.59 4.8-2.5 6.71-1.83 1.94-4.17 2.97-7.32 2.97-5.78 0-10.48-4.7-10.48-10.47S5.71.81 11.49.81c3.11 0 5.38 1.22 7.05 2.81l-1.99 1.98c-1.2-1.12-2.81-1.98-5.06-1.98-4.06 0-7.25 3.35-7.25 7.49s3.19 7.48 7.25 7.48c2.64 0 4.14-1.06 5.1-2.02.78-.78 1.29-1.9 1.49-3.44z" />
            </svg>
          </span>
          <span>Google ile Devam Et</span>
        </button>

        <p id="message" class="min-h-[1.25rem] text-xs text-center text-red-300"></p>

        <p class="text-[11px] text-sky-100/60 text-center max-w-sm">
          Giriş yaparak Agora Go Akademisi'nin kullanım şartlarını ve gizlilik politikasını kabul etmiş olursun.
        </p>
      </section>
    </div>
  </main>

  <script>
    import { supabase } from '../lib/supabase';

    const messageBox = document.getElementById('message');

    document.getElementById('google-login')?.addEventListener('click', async () => {
      if (messageBox) {
        messageBox.textContent = '';
      }
      const { error } = await supabase.auth.signInWithOAuth({
        provider: 'google',
        options: { redirectTo: window.location.origin + '/goagaci' }
      });

      if (error && messageBox) {
        messageBox.textContent = 'Giriş başarısız: ' + error.message;
      }
    });
  </script>
</Layout>