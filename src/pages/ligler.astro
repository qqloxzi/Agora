---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";

interface Match {
    p1: string;
    p2: string;
    s1: number;
    s2: number;
}

interface WeekFixture {
    week: string;
    matches: Match[];
}

interface League {
    id: number;
    name: string;
    sub: string;
    status: string;
    participants: string[];
    fixtures: WeekFixture[];
    standings?: Standing[];
}

interface Standing {
    rank: number;
    name: string;
    played: number;
    points: number;
}

// Oyuncular ve fikstür sıfırlandı
const defaultParticipants: string[] = [];
const genericFixtures: WeekFixture[] = [];

const leaguesData: League[] = [
  {
    id: 1,
    name: "Temel Taşlar Ligi",
    sub: "17-12 Kyu",
    status: "Kayıtlar açık", 
    participants: [...defaultParticipants],
    fixtures: [...genericFixtures]
  },
  {
    id: 2,
    name: "Gelişim Ligi",
    sub: "11-6 Kyu",
    status: "Kayıtlar açık",
    participants: [...defaultParticipants],
    fixtures: [...genericFixtures]
  },
  {
    id: 3,
    name: "Aydınlanma Ligi",
    sub: "5 kyu - 1 Dan",
    status: "Kayıtlar açık",
    participants: [...defaultParticipants],
    fixtures: [...genericFixtures]
  }
];

const leagues = leaguesData.map((league) => {
    let standingsMap: Record<string, { name: string; played: number; points: number }> = {};
    league.participants.forEach(p => { standingsMap[p] = { name: p, played: 0, points: 0 }; });

    league.fixtures.forEach(week => {
        week.matches.forEach(match => {
            if (match.s1 > 0 || match.s2 > 0) {
                if(standingsMap[match.p1]) { standingsMap[match.p1].played += 1; standingsMap[match.p1].points += match.s1; }
                if(standingsMap[match.p2]) { standingsMap[match.p2].played += 1; standingsMap[match.p2].points += match.s2; }
            }
        });
    });

    let standingsArray = Object.values(standingsMap).sort((a, b) => {
        if (b.points !== a.points) return b.points - a.points;
        return a.name.localeCompare(b.name);
    });

    const rankedStandings: Standing[] = standingsArray.map((item, index) => ({ ...item, rank: index + 1 }));
    return { ...league, standings: rankedStandings };
});
---

<Layout title="Ligler">
  <Container>
      <Sectionhead>
        <Fragment slot="title">Lig Fikstürü ve Puan Durumu</Fragment>
        <Fragment slot="desc">Güncel maç sonuçları, haftalık eşleşmeler ve liderlik tablosu.</Fragment>
      </Sectionhead>
    </div>

    <div class="mt-8 flex flex-col gap-10">
      {leagues.map((item) => (
        <div class="w-full bg-white dark:bg-slate-900 rounded-2xl p-6 md:p-10 border border-slate-200 dark:border-slate-800 shadow-sm">
            
            {/* LİG BAŞLIĞI */}
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8 pb-6 border-b border-slate-100 dark:border-slate-800">
                <div>
                    <h2 class="text-2xl font-bold text-slate-900 dark:text-white">{item.name}</h2>
                    <p class="text-slate-500 dark:text-slate-400 mt-1 text-sm">{item.sub}</p>
                </div>
                <span class={`inline-flex items-center px-4 py-1.5 rounded-full text-xs font-bold ${item.status === 'Kayıtlar açık' ? 'bg-green-50 text-green-700 border border-green-200 dark:bg-green-900/20 dark:border-green-800 dark:text-green-400' : 'bg-slate-50 text-slate-600 border border-slate-200 dark:bg-slate-800 dark:border-slate-700 dark:text-slate-300'}`}>
                   {item.status}
                </span>
            </div>

            <div class="grid grid-cols-1 xl:grid-cols-12 gap-10">
                
                {/* SOL: PUAN TABLOSU */}
                <div class="xl:col-span-5 bg-slate-50/50 dark:bg-slate-800/30 rounded-xl p-6 border border-slate-100 dark:border-slate-800/50">
                    <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Puan Durumu</h3>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse min-w-[250px]">
                            <thead>
                                <tr class="text-xs font-medium tracking-wide text-slate-500 uppercase border-b border-slate-200 dark:border-slate-700">
                                    <th class="py-3 pr-2 w-8 text-center">#</th>
                                    <th class="py-3">Oyuncu</th>
                                    <th class="py-3 text-center w-12">OM</th>
                                    <th class="py-3 text-right w-12">P</th>
                                </tr>
                            </thead>
                            <tbody class="text-sm">
                                {item.standings && item.standings.length > 0 ? item.standings.map((s) => (
                                    <tr class="border-b border-slate-100 dark:border-slate-800 last:border-0 hover:bg-white dark:hover:bg-slate-800/50 transition-colors">
                                        <td class="py-3 pr-2 text-center text-slate-400">{s.rank}.</td>
                                        <td class="py-3 text-slate-700 dark:text-slate-300">{s.name}</td>
                                        <td class="py-3 text-center text-slate-500">{s.played}</td>
                                        <td class="py-3 text-right text-slate-900 dark:text-white font-bold">{s.points}</td>
                                    </tr>
                                )) : (
                                    <tr>
                                        <td colspan="4" class="py-6 text-center text-slate-400 italic text-xs">Henüz oyuncu bulunmamaktadır.</td>
                                    </tr>
                                )}
                            </tbody>
                        </table>
                    </div>
                </div>

                {/* SAĞ: FİKSTÜR */}
                <div class="xl:col-span-7">
                    <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Maç Fikstürü</h3>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        {item.fixtures && item.fixtures.length > 0 ? item.fixtures.map((fix) => (
                            <div class="bg-white dark:bg-slate-900 p-4 rounded-xl border border-slate-100 dark:border-slate-800">
                                <div class="text-xs font-medium text-slate-400 uppercase tracking-widest mb-3 pb-2 border-b border-slate-50 dark:border-slate-800/50 text-center">
                                    {fix.week}
                                </div>
                                <div class="flex flex-col gap-2">
                                    {fix.matches.map((m) => (
                                        <div class="flex items-center justify-between text-sm py-1">
                                            <span class={`w-1/3 truncate text-right ${m.s1 > m.s2 ? 'font-medium text-slate-800 dark:text-slate-200' : 'text-slate-500 dark:text-slate-400'}`}>
                                                {m.p1}
                                            </span>
                                            
                                            <div class="flex items-center justify-center gap-1 w-1/3 text-xs bg-slate-50 dark:bg-slate-800/50 rounded px-2 py-1">
                                                <span class={`${m.s1 > 0 || m.s2 > 0 ? 'text-slate-800 dark:text-slate-200' : 'text-slate-400'}`}>{m.s1}</span>
                                                <span class="text-slate-300 dark:text-slate-600">-</span>
                                                <span class={`${m.s1 > 0 || m.s2 > 0 ? 'text-slate-800 dark:text-slate-200' : 'text-slate-400'}`}>{m.s2}</span>
                                            </div>

                                            <span class={`w-1/3 truncate text-left ${m.s2 > m.s1 ? 'font-medium text-slate-800 dark:text-slate-200' : 'text-slate-500 dark:text-slate-400'}`}>
                                                {m.p2}
                                            </span>
                                        </div>
                                    ))}
                                </div>
                            </div>
                        )) : (
                            <div class="col-span-full py-10 px-4 border border-dashed border-slate-200 dark:border-slate-800 rounded-xl text-center">
                                <p class="text-slate-400 dark:text-slate-500 text-sm italic">Fikstür sezon başladığında açıklanacaktır.</p>
                            </div>
                        )}
                    </div>
                </div>

            </div>
        </div>
      ))}
    </div>
  </Container>
</Layout>