---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Giriş Yap / Kayıt Ol">
  <main class="min-h-screen flex items-center justify-center bg-slate-50 dark:bg-slate-950 px-4 py-16">
    <section class="w-full max-w-md rounded-2xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 shadow-sm px-6 py-8 flex flex-col gap-6">
      <div class="flex flex-col items-start gap-2 text-left">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400 dark:text-slate-500">
          Agora Go Akademisi
        </p>
        <h1 class="text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">
          Tek adımla giriş yap
        </h1>
        <p class="text-sm text-slate-600 dark:text-slate-400">
          E-posta ve şifre yok. Sadece Google hesabınla giriş yap ve ilerlemen otomatik kaydedilsin.
        </p>
      </div>

      <button
        id="google-btn"
        class="inline-flex w-full items-center justify-center gap-3 rounded-lg bg-slate-900 text-white px-4 py-2.5 text-sm font-medium shadow-sm hover:bg-slate-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-500 disabled:opacity-60"
      >
        <span class="inline-flex h-5 w-5 items-center justify-center rounded-sm bg-white">
          <svg class="h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="#EA4335" d="M11.99 13.19v-2.72h9.18c.09.49.14 1.06.14 1.72 0 2.14-.59 4.8-2.5 6.71-1.83 1.94-4.17 2.97-7.32 2.97-5.78 0-10.48-4.7-10.48-10.47S5.71.81 11.49.81c3.11 0 5.38 1.22 7.05 2.81l-1.99 1.98c-1.2-1.12-2.81-1.98-5.06-1.98-4.06 0-7.25 3.35-7.25 7.49s3.19 7.48 7.25 7.48c2.64 0 4.14-1.06 5.1-2.02.78-.78 1.29-1.9 1.49-3.44z" />
          </svg>
        </span>
        <span>Google ile Devam Et</span>
      </button>

      <p id="error-msg" class="min-h-[1.25rem] text-xs text-center text-red-500"></p>

      <p class="text-[11px] text-slate-500 dark:text-slate-500 text-center">
        İlk kez giriş yapıyorsan, Google hesabınla otomatik olarak bir profil oluşturulur.
      </p>
    </section>
  </main>
</Layout>

<script>
  import { supabase } from "../lib/supabase";

  const googleBtn = document.getElementById("google-btn") as HTMLButtonElement | null;
  const errorMsg = document.getElementById("error-msg") as HTMLParagraphElement | null;

  if (googleBtn) {
    googleBtn.addEventListener("click", async () => {
      if (errorMsg) errorMsg.textContent = "";
      const { error } = await supabase.auth.signInWithOAuth({
        provider: "google",
        options: { redirectTo: window.location.origin + "/goagaci" },
      });

      if (error && errorMsg) {
        errorMsg.textContent = "Giriş başarısız: " + error.message;
      }
    });
  }
</script>