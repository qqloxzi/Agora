---
import Container from "@components/container.astro";
import Layout from "@layouts/Layout.astro";
import Ligler from "@components/ligler.astro";
import Faq from "@components/faq.astro";
---

<Layout title="Ana Sayfa- Agora Go Akademisi">

  <Container>
    <section class="w-full pt-16 md:pt-20">
      <div id="user-welcome" class="hidden relative overflow-hidden rounded-3xl border border-slate-200/80 bg-gradient-to-br from-slate-900 via-slate-950 to-slate-900 px-6 py-6 md:px-8 md:py-7 text-white shadow-xl mb-10">
        <div class="pointer-events-none absolute inset-0 opacity-40 mix-blend-screen">
          <div class="absolute -top-10 -right-10 h-40 w-40 rounded-full bg-indigo-500/40 blur-3xl"></div>
          <div class="absolute -bottom-12 -left-6 h-36 w-36 rounded-full bg-emerald-400/40 blur-3xl"></div>
        </div>

        <div class="relative flex flex-col md:flex-row md:items-center md:justify-between gap-5">
          <div class="flex items-start gap-3">
            <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-white/10 ring-1 ring-white/20">
              <span id="welcome-avatar" class="text-xl font-semibold">🙂</span>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-sky-300/80 mb-1">
                Kişisel çalışma alanın
              </p>
              <h1 class="text-xl md:text-2xl font-semibold tracking-tight mb-1">
                Hoş geldin <span id="welcome-name" class="font-bold">Oyuncu</span>!
              </h1>
              <p class="text-xs md:text-sm text-slate-200/80">
                Bugün Go çalışmak için harika bir gün. Hadi <span class="font-semibold text-emerald-300" id="welcome-rank">30 Kyu</span> seviyeni bir adım daha ileri taşıyalım.
              </p>
            </div>
          </div>

          <div class="flex flex-col gap-2 md:items-end">
            <div class="flex items-center gap-2 text-[11px] font-medium text-slate-200/80">
              <span class="inline-flex h-6 items-center rounded-full bg-white/10 px-2.5">
                Günlük hedef: <span id="welcome-daily-goal" class="ml-1 font-semibold text-emerald-200">3 soru</span>
              </span>
            </div>
            <div class="w-full md:w-60">
              <div class="flex justify-between text-[10px] text-slate-300 mb-1.5">
                <span>Bugünkü ilerleme</span>
                <span id="welcome-progress-label">0%</span>
              </div>
              <div class="h-1.5 w-full rounded-full bg-slate-800/80 overflow-hidden">
                <div id="welcome-progress-bar" class="h-full rounded-full bg-gradient-to-r from-sky-400 via-indigo-400 to-emerald-300 transition-all duration-700" style="width: 0%"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <section class="w-full pb-12 flex items-center justify-center text-center">
        <div class="max-w-4xl w-full mx-auto flex flex-col items-center">
          <h2 class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-slate-900 dark:text-white leading-[1.1] tracking-tight mb-6">
            Çevrimiçi <span class="text-blue-600 dark:text-blue-500">Go</span><br />
            <span class="text-indigo-500 dark:text-indigo-400">Eğitim</span> Platformu
          </h2>
          <p class="text-lg md:text-xl text-slate-600 dark:text-slate-400 max-w-2xl leading-relaxed font-medium mx-auto">
            Stratejik derinliğinizi artırın. Temel Taşlar, Gelişim ve Aydınlanma liglerinde, uzman eğitmenlerle Go dünyasının inceliklerini keşfedin.
          </p>
        </div>
      </section>

      <!-- Kurslar: 3 kurs dinamik (courses tablosundan) -->
      <section class="w-full pb-20" id="home-courses-section">
        <div class="max-w-4xl mx-auto text-center mb-10">
          <span class="text-blue-600 dark:text-blue-400 font-bold tracking-wider uppercase text-sm">Eğitim Programları</span>
          <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 dark:text-white mt-2 mb-2">Kurslar</h2>
          <p class="text-slate-600 dark:text-slate-400 max-w-xl mx-auto">Seçilen 3 ligi aşağıda inceleyebilir, tüm listeye Eğitim Programları sayfasından ulaşabilirsiniz.</p>
        </div>
        <div id="home-courses-loading" class="flex flex-col items-center justify-center py-12">
          <div class="w-10 h-10 border-4 border-blue-600 border-t-transparent rounded-full animate-spin mb-3"></div>
          <span class="text-slate-500 dark:text-slate-400 text-sm">Kurslar yükleniyor...</span>
        </div>
        <div id="home-courses-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto hidden"></div>
        <div class="text-center mt-8">
          <a href="/courses" class="inline-flex items-center justify-center px-6 py-3 text-sm font-semibold text-white bg-slate-800 dark:bg-slate-200 dark:text-slate-900 rounded-full hover:bg-slate-700 dark:hover:bg-slate-300 transition-colors">
            Tüm Eğitim Programları
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
          </a>
        </div>
      </section>
    </section>
    <Ligler />
    <Faq />
    
  </Container>

</Layout>

<script>
  import { supabase } from "../lib/supabase";

  async function initWelcome() {
    const { data: { user } } = await supabase.auth.getUser();
    if (!user) return;

    const box = document.getElementById("user-welcome");
    const nameEl = document.getElementById("welcome-name");
    const avatarEl = document.getElementById("welcome-avatar");
    const rankEl = document.getElementById("welcome-rank");
    const goalEl = document.getElementById("welcome-daily-goal");
    const progressBar = document.getElementById("welcome-progress-bar");
    const progressLabel = document.getElementById("welcome-progress-label");

    if (box) box.classList.remove("hidden");

    let displayName = user.user_metadata?.full_name || user.email?.split("@")[0] || "Oyuncu";
    if (nameEl) nameEl.textContent = displayName;
    if (avatarEl) avatarEl.textContent = (displayName[0] || "🙂").toUpperCase();

    const { data: profile } = await supabase
      .from("agorasusers")
      .select("*")
      .eq("id", user.id)
      .single();

    const rankText = profile?.rank || "30 Kyu";
    if (rankEl) rankEl.textContent = rankText;

    const dailyGoal = profile?.daily_goal || "3 soru";
    if (goalEl) goalEl.textContent = dailyGoal;

    const todayProgress = typeof profile?.today_progress === "number" ? profile.today_progress : 0;
    const clamped = Math.max(0, Math.min(100, todayProgress));
    if (progressBar) progressBar.style.width = clamped + "%";
    if (progressLabel) progressLabel.textContent = clamped + "%";
  }

  function getKyuRange(level) {
    switch (level) {
      case "Temel Taşlar": return "17–12 Kyu";
      case "Gelişime": return "11–6 Kyu";
      case "Aydınlanmaya": return "5 Kyu – 1 Dan";
      default: return "";
    }
  }

  async function loadHomeCourses() {
    const grid = document.getElementById("home-courses-grid");
    const loading = document.getElementById("home-courses-loading");
    if (!grid || !loading) return;

    const { data: courses, error } = await supabase
      .from("courses")
      .select("*")
      .order("created_at", { ascending: false })
      .limit(3);

    loading.classList.add("hidden");
    if (error || !courses || courses.length === 0) {
      grid.classList.remove("hidden");
      grid.innerHTML = "<p class='col-span-full text-center text-slate-500 dark:text-slate-400 py-8'>Şu an listelenecek lig yok. <a href='/courses' class='text-blue-600 dark:text-blue-400 underline'>Eğitim Programları</a> sayfasını ziyaret edin.</p>";
      return;
    }

    grid.classList.remove("hidden");
    grid.innerHTML = courses.map((course) => {
      const kyuInfo = getKyuRange(course.level);
      const kyuBadge = kyuInfo
        ? `<span class="bg-blue-600 text-white text-[10px] font-bold px-2 py-1 rounded shadow-md uppercase tracking-wide">${kyuInfo}</span>`
        : "";
      return `
        <a href="/course-detail?slug=${encodeURIComponent(course.slug)}" class="flex flex-col bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300 h-full group">
          <div class="relative h-40 w-full overflow-hidden">
            <img src="${course.image_url || "https://via.placeholder.com/400x250"}" alt="${course.title}" class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700" />
            <div class="absolute top-2 right-2">
              <span class="bg-white/95 dark:bg-gray-900/90 backdrop-blur-sm text-[10px] font-bold px-2 py-1 rounded shadow-sm text-gray-700 dark:text-gray-200 uppercase tracking-wide">${course.level || "Lig"}</span>
            </div>
            <div class="absolute bottom-2 left-2">${kyuBadge}</div>
          </div>
          <div class="p-4 flex flex-col flex-grow">
            <div class="flex items-center gap-2 mb-2">
              <div class="w-6 h-6 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded flex items-center justify-center shrink-0">
                <span class="text-[10px] font-bold text-gray-500 dark:text-gray-300">${course.provider ? course.provider.substring(0,1) : "A"}</span>
              </div>
              <span class="text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wide truncate">${course.provider || "Agora Academy"}</span>
            </div>
            <h3 class="font-bold text-gray-900 dark:text-white text-base leading-tight line-clamp-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">${course.title}</h3>
            <div class="mt-auto pt-3 flex justify-end">
              <div class="flex items-center justify-center w-9 h-9 rounded-full bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 group-hover:bg-blue-600 group-hover:text-white transition-all duration-300 shadow-sm">
                <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
              </div>
            </div>
          </div>
        </a>
      `;
    }).join("");
  }

  initWelcome();
  loadHomeCourses();
</script>