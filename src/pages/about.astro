---
import { getCollection } from "astro:content";
import { Picture } from "astro:assets";
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";

// 1. Ekip üyelerini filtrele
const publishedTeamMembers = await getCollection("team", ({ data }) => {
  return !data.draft && data.publishDate < new Date();
});

// 2. Markdown içeriğini (Body kısmını) render etmek için hazırlık yapıyoruz
const teamMembersWithContent = await Promise.all(
  publishedTeamMembers.map(async (member) => {
    const { Content } = await member.render();
    return { ...member, Content };
  })
);

// 3. İsimleri dosya adına çeviren yardımcı fonksiyon
function generateInstructorLink(name: string) {
  return "/instructor/" + name
    .toLowerCase()
    .replace(/ğ/g, 'g')
    .replace(/ü/g, 'u')
    .replace(/ş/g, 's')
    .replace(/ı/g, 'i')
    .replace(/ö/g, 'o')
    .replace(/ç/g, 'c')
    .replace(/\s+/g, ''); 
}
---

<Layout title="Hakkımızda - Agora Go Akademisi">
  <Container>
    <Sectionhead>
      <Fragment slot="title">Hakkımızda</Fragment>
      <Fragment slot="desc">
        <p class="text-gray-600 dark:text-gray-300">
          Agora Go Akademisi olarak vizyonumuz, her seviyedeki oyuncunun gelişimine katkı sağlamak, go kültürünü yaymak ve oyunun Türkiye'de daha geniş kitlelere ulaşmasını sağlamaktır.
        </p>
      </Fragment>
    </Sectionhead>

    <div class="mt-16 max-w-4xl mx-auto">
      
    </div>

    <div class="grid md:grid-cols-3 gap-10 mx-auto max-w-4xl mt-16">
      {
        teamMembersWithContent.map((item) => (
          <a 
            href={generateInstructorLink(item.data.name)} 
            class="group block hover:-translate-y-1 transition-transform duration-300"
          >
            <div class="w-full aspect-square overflow-hidden rounded-md bg-slate-100 dark:bg-slate-800 relative">  
              <Picture
                src={item.data.avatar.src}
                alt={item.data.avatar.alt}
                sizes="(max-width: 800px) 100vw, 400px"
                width={400}
                height={400}
                class="w-full h-full object-cover object-center transition duration-500 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors duration-300 flex items-center justify-center">
                  <span class="opacity-0 group-hover:opacity-100 bg-white/90 dark:bg-gray-800 text-gray-800 dark:text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg transform translate-y-4 group-hover:translate-y-0 transition-all duration-300">
                    Profili İncele →
                  </span>
              </div>
            </div>

            <div class="mt-5 text-center">
              <h2 class="text-xl font-bold text-gray-800 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                {item.data.name}
              </h2>
              
              {/* Seviyeler (4 Dan vb.) daha büyük ve belirgin */}
              <p class="text-lg font-bold text-blue-600 dark:text-blue-400 mt-2 mb-4">
                {item.data.title}
              </p>
              
              {/* Açıklama alanı: markdown içindeki başlık/kalınlık ezildi, eşit boyuta getirildi */}
              <div class="text-gray-700 dark:text-gray-300 text-base leading-relaxed px-2 [&>*]:text-base [&>*]:font-normal">
                <item.Content />
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </Container>
</Layout>