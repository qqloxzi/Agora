---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Tüm Eğitimler | Agora Go">
    
    <div class="bg-[#F5F7F8] dark:bg-gray-950 min-h-screen font-sans text-gray-800 dark:text-gray-200 py-12 transition-colors duration-300">
        
        <div class="max-w-[1400px] mx-auto px-6">
            
            <!-- BAŞLIK ALANI -->
            <div class="text-center max-w-3xl mx-auto mb-12">
                <span class="text-blue-600 dark:text-blue-400 font-bold tracking-wider uppercase text-sm mb-2 block">Agora Go Akademisi</span>
                <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-4">Eğitim Programları</h1>
            </div>

           <!-- 2. SEZON DUYURU ALANI -->
            <div class="mb-20 mt-8 relative">
                
                <!-- Üst ve Alt Dekoratif Çizgiler -->
                <div class="absolute top-0 left-1/2 -translate-x-1/2 w-24 h-1 bg-gray-900 dark:bg-white rounded-full opacity-10"></div>
                <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-24 h-1 bg-gray-900 dark:bg-white rounded-full opacity-10"></div>

                <div class="py-12 px-4 text-center">
                    
                    <!-- Üst Başlık (Badge) -->
                    <div class="flex justify-center mb-6">
                        <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-gray-200 dark:border-gray-700 bg-transparent text-xs font-bold tracking-[0.2em] uppercase text-gray-900 dark:text-white">
                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                            Kayıtlar Başladı
                        </span>
                    </div>

                    <!-- Ana Başlık -->
                    <h2 class="text-4xl md:text-5xl font-black text-gray-900 dark:text-white mb-4 tracking-tight">
                        2. Sezona hazır mısınız?
                    </h2>
                    
                    <!-- Tarih -->
                    <p class="text-xl text-gray-500 dark:text-gray-400 font-light mb-10">
                        Başlangıç: <strong class="text-gray-900 dark:text-white font-semibold">13 Nisan 2026</strong>
                    </p>

                    <!-- Özellikler Grid'i -->
                    <div class="max-w-4xl mx-auto grid md:grid-cols-3 gap-8 mb-10 border-t border-b border-gray-100 dark:border-gray-800 py-10">
                        
                        <div class="flex flex-col items-center gap-3">
                            <div class="w-10 h-10 flex items-center justify-center rounded-full bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white mb-2">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>
                            </div>
                            <h3 class="font-bold text-gray-900 dark:text-white">Online Lig Katılımı</h3>
                            <p class="text-sm text-gray-500 dark:text-gray-400">Rekabetçi ortamda seviyenizi test edin.</p>
                        </div>

                        <div class="flex flex-col items-center gap-3 md:border-l md:border-r border-gray-100 dark:border-gray-800 px-4">
                            <div class="w-10 h-10 flex items-center justify-center rounded-full bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white mb-2">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
                            </div>
                            <h3 class="font-bold text-gray-900 dark:text-white">Bireysel Oyun Analizi</h3>
                            <p class="text-sm text-gray-500 dark:text-gray-400">Her hafta maçlarınız detaylıca incelenir.</p>
                        </div>

                        <div class="flex flex-col items-center gap-3">
                            <div class="w-10 h-10 flex items-center justify-center rounded-full bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white mb-2">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                            </div>
                            <h3 class="font-bold text-gray-900 dark:text-white">Ders Kayıtlarına Erişim</h3>
                            <p class="text-sm text-gray-500 dark:text-gray-400">Kaçırdığınız dersleri dilediğiniz zaman izleyin.</p>
                        </div>

                    </div>

                    <!-- Kontenjan Uyarısı -->
                    <div class="text-center">
                        <p class="text-sm font-medium text-gray-500 dark:text-gray-400">
                            *Liglerin verimli ve anlamlı olabilmesi adına kontenjan <span class="text-red-600 dark:text-red-400 font-bold underline decoration-2 underline-offset-4">8 kişi</span> ile sınırlıdır.
                        </p>
                    </div>

                </div>
            </div>

            <!-- YÜKLENİYOR SİMGESİ -->
            <div id="loading" class="flex flex-col items-center justify-center py-20">
                <div class="w-12 h-12 border-4 border-blue-600 border-t-transparent rounded-full animate-spin mb-4"></div>
                <span class="text-gray-500 dark:text-gray-400 font-medium text-lg">Ligler listeleniyor...</span>
            </div>

            <!-- Kurs kartları flex ile ortalanır -->
            <div id="course-grid" class="flex flex-wrap justify-center gap-8 hidden w-full">
            </div>
        </div>

    </div>

    <script>
        function getKyuRange(level) {
            switch (level) {
                case "Temel Taşlar":
                    return "17–12 Kyu";
                case "Gelişime":
                    return "11–6 Kyu";
                case "Aydınlanmaya":
                    return "5 Kyu – 1 Dan";
                default:
                    return "";
            }
        }

        import { createClient } from '@supabase/supabase-js';

        const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
        const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
        const supabase = createClient(supabaseUrl, supabaseKey);

        async function loadCourses() {
            const grid = document.getElementById('course-grid');
            const loading = document.getElementById('loading');

            if (!grid || !loading) return;

            const { data: courses, error } = await supabase
                .from('courses')
                .select('*')
                .order('created_at', { ascending: false });

            if (error || !courses) {
                loading.innerHTML = "<p class='text-red-500'>Ligler yüklenirken hata oluştu.</p>";
                return;
            }

            if (courses.length === 0) {
                loading.innerHTML = "<p class='dark:text-gray-300'>Henüz aktif bir Lig bulunmuyor.</p>";
                return;
            }

            loading.classList.add('hidden');
            grid.classList.remove('hidden');

            courses.forEach((course: any) => {
                
                const kyuInfo = getKyuRange(course.level);
                const kyuBadge = kyuInfo 
                    ? `<span class="bg-blue-600 text-white text-[10px] font-bold px-2 py-1 rounded shadow-md uppercase tracking-wide">
                        ${kyuInfo}
                       </span>` 
                    : '';

                // DÜZELTME: Kartlara sabit genişlik (sm:w-[360px]) verildi.
                // Flex yapısında kartların çok genişlemesini veya daralmasını engeller.
                const cardHTML = `
                    <a href="/course-detail?slug=${course.slug}" class="flex flex-col bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300 h-full group relative w-full sm:w-[360px]">
                        
                        <div class="relative h-48 w-full overflow-hidden">
                            <img 
                                src="${course.image_url || 'https://via.placeholder.com/400x250'}" 
                                alt="${course.title}" 
                                class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700" 
                            />
                            
                            <div class="absolute top-3 right-3 flex gap-2">
                                <span class="bg-white/95 dark:bg-gray-900/90 backdrop-blur-sm text-[10px] font-bold px-2 py-1 rounded shadow-sm text-gray-700 dark:text-gray-200 uppercase tracking-wide">
                                    ${course.level || 'Lig'}
                                </span>
                            </div>

                            <div class="absolute bottom-3 left-3">
                                ${kyuBadge}
                            </div>
                        </div>

                        <div class="p-5 flex flex-col flex-grow relative">
                            
                            <div class="flex items-center gap-2 mb-3">
                                <div class="w-6 h-6 bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded flex items-center justify-center overflow-hidden shrink-0">
                                     <span class="text-[10px] font-bold text-gray-500 dark:text-gray-300">${course.provider ? course.provider.substring(0,1) : 'A'}</span>
                                </div> 
                                <span class="text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wide truncate">${course.provider || 'Agora Academy'}</span>
                            </div>
                            
                            <h3 class="font-bold text-gray-900 dark:text-white text-lg leading-tight mb-2 line-clamp-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                                ${course.title}
                            </h3>

                            <div class="mt-auto pt-4 flex justify-end">
                                <div class="flex items-center justify-center w-10 h-10 rounded-full bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 group-hover:bg-blue-600 group-hover:text-white transition-all duration-300 shadow-sm">
                                    <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                                </div>
                            </div>

                        </div>
                    </a>
                `;
                grid.innerHTML += cardHTML;
            });
        }

        loadCourses();
    </script>
</Layout>